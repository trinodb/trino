            <id>confluent</id>
            <url>https://packages.confluent.io/maven/</url>
        </repository>
    </repositories>

    <build>
        <testResources>
            <testResource>
                <filtering>true</filtering>
                <directory>src/test/resources</directory>
                <includes>
                    <include>trino-cli-version.txt</include>
                </includes>
            </testResource>
            <testResource>
                <filtering>false</filtering>
                <directory>src/test/resources</directory>
                <excludes>
                    <exclude>trino-cli-version.txt</exclude>
                </excludes>
            </testResource>
        </testResources>

        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <configuration>
                    <ignoredUnusedDeclaredDependencies>
                        <!-- Used by test-only container/environment code in this commit -->
                        <ignoredUnusedDeclaredDependency>com.github.docker-java:docker-java-api</ignoredUnusedDeclaredDependency>
                        <!-- Used by AbstractTestingTrinoClient via reflection -->
                        <ignoredUnusedDeclaredDependency>io.airlift:testing</ignoredUnusedDeclaredDependency>
                        <ignoredUnusedDeclaredDependency>io.airlift:http-client</ignoredUnusedDeclaredDependency>
                        <ignoredUnusedDeclaredDependency>org.apache.parquet:parquet-common</ignoredUnusedDeclaredDependency>
                        <ignoredUnusedDeclaredDependency>software.amazon.awssdk:s3</ignoredUnusedDeclaredDependency>
                        <ignoredUnusedDeclaredDependency>software.amazon.awssdk:sdk-core</ignoredUnusedDeclaredDependency>
                    </ignoredUnusedDeclaredDependencies>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <!-- Product tests in this module run via suite entrypoints (exec:java / CI suite jobs).
                         Surefire excludes the whole product-test package tree and only sees the small
                         verification tests that live outside it. -->
                    <excludes>
                        <exclude>**/io/trino/tests/product/*.java</exclude>
                        <exclude>**/io/trino/tests/product/**/*.java</exclude>
                    </excludes>
                    <!-- Product tests require sequential execution because they share a single
                         environment at a time via EnvironmentManager. Parallel execution would
                         cause environment conflicts. -->
                    <systemPropertyVariables>
                        <junit.jupiter.execution.parallel.enabled>false</junit.jupiter.execution.parallel.enabled>
                    </systemPropertyVariables>
                </configuration>
                <dependencies>
                    <!-- JUnit platform provider for framework sanity tests in this module -->
                    <dependency>
                        <groupId>org.apache.maven.surefire</groupId>
                        <artifactId>surefire-junit-platform</artifactId>
                        <version>${dep.plugin.surefire.version}</version>
                    </dependency>
                </dependencies>
            </plugin>
        </plugins>
    </build>
