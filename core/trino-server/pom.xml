    <!-- Needed to resolve the plugin archives staged into this package -->
    <repositories>
        <repository>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
            <id>confluent</id>
            <url>https://packages.confluent.io/maven/</url>
        </repository>
    </repositories>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <executions>
                    <execution>
                        <id>stage-plugins</id>
                        <goals>
                            <goal>copy-dependencies</goal>
                        </goals>
                        <phase>prepare-package</phase>
                        <configuration>
                            <!-- air.check.skip-dependency disables the analyzer, not the staging done here -->
                            <skip>false</skip>
                            <outputDirectory>${plugin.archives.directory}</outputDirectory>
                            <!-- The archives packaged into this distribution are the provided scope zips -->
                            <includeScope>provided</includeScope>
                            <includeTypes>zip</includeTypes>
                            <!-- The assembler maps trino-<name>.zip onto plugin/<name> -->
                            <stripVersion>true</stripVersion>
                        </configuration>
                    </execution>
                    <execution>
                        <id>stage-archives</id>
                        <goals>
                            <goal>copy</goal>
                        </goals>
                        <phase>prepare-package</phase>
                        <configuration>
                            <!-- air.check.skip-dependency disables the analyzer, not the staging done here -->
                            <skip>false</skip>
                            <artifactItems>
                                <!-- Expanded at the root; supplies bin, lib, NOTICE and the core plugins -->
                                <artifactItem>
                                    <groupId>io.trino</groupId>
                                    <artifactId>trino-server-core</artifactId>
                                    <version>${project.version}</version>
                                    <type>tar.gz</type>
                                    <outputDirectory>${assembly.stage.directory}</outputDirectory>
                                </artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <dependencies>
                    <dependency>
                        <groupId>io.trino</groupId>
                        <artifactId>trino-server-assembler</artifactId>
                        <version>${project.version}</version>
                    </dependency>
                </dependencies>
                <executions>
                    <execution>
                        <id>assemble-server</id>
                        <goals>
                            <goal>java</goal>
                        </goals>
                        <phase>package</phase>
                        <configuration>
                            <executableDependency>
                                <groupId>io.trino</groupId>
                                <artifactId>trino-server-assembler</artifactId>
                            </executableDependency>
                            <includePluginDependencies>true</includePluginDependencies>
                            <includeProjectDependencies>false</includeProjectDependencies>
                            <classpathScope>runtime</classpathScope>
                            <mainClass>io.trino.server.assembler.ServerAssembler</mainClass>
                            <arguments>
                                <argument>--stage</argument>
                                <argument>${assembly.stage.directory}</argument>
                                <argument>--plugins</argument>
                                <argument>${plugin.archives.directory}</argument>
                                <argument>--output</argument>
                                <argument>${project.build.directory}/${project.artifactId}-${project.version}.tar.gz</argument>
                                <argument>--root-directory</argument>
                                <argument>${project.artifactId}-${project.version}</argument>
                                <!-- The plugin reader runs against this tree in CI -->
                                <argument>--explode</argument>
                                <argument>${assembly.directory}</argument>
                                <argument>--timestamp</argument>
                                <argument>${project.build.outputTimestamp}</argument>
                                <argument>--overlay</argument>
                                <argument>trino-hdfs=delta-lake,hive,hudi,iceberg,lakehouse</argument>
                            </arguments>
                            <!--
                            bin/launcher.properties is not filtered here. It arrives already
                            substituted from the trino-server-core archive and so keeps
                            process-name=trino-server-core, matching the Provisio behaviour.
                            -->
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>build-helper-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>attach-server</id>
                        <goals>
                            <goal>attach-artifact</goal>
                        </goals>
                        <phase>package</phase>
                        <configuration>
                            <artifacts>
                                <artifact>
                                    <file>${project.build.directory}/${project.artifactId}-${project.version}.tar.gz</file>
                                    <type>tar.gz</type>
                                </artifact>
                            </artifacts>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-enforcer-plugin</artifactId>
                <configuration>
                    <rules combine.self="override">
                        <requireFilesSize>
                            <!-- Maven Central has a 1GB limit -->
                            <maxsize>1073741824</maxsize>
                            <files>
                                <file>${project.build.directory}/${project.artifactId}-${project.version}.tar.gz</file>
                            </files>
                        </requireFilesSize>
